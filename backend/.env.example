# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/ai_task_platform

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TASK_QUEUE=ai:tasks:queue

# JWT access token (short-lived, sent in response body, kept in memory by the client)
JWT_ACCESS_SECRET=change-this-to-a-long-random-string-access
JWT_ACCESS_EXPIRES_IN=15m

# JWT refresh token (long-lived, sent only via httpOnly cookie, hash stored in MongoDB)
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string-refresh
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_TTL_MS=2592000000

# Refresh cookie
REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_PATH=/api/auth
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
# COOKIE_DOMAIN=.example.com

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
